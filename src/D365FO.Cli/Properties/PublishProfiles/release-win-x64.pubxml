<!--
  Release publish profile: single-file, self-contained, ReadyToRun.
  Spectre.Console is NOT trim-safe, so trimming is left off.

  Usage:
    dotnet publish src/D365FO.Cli -c Release /p:PublishProfile=release-win-x64
    dotnet publish src/D365FO.Cli -c Release /p:PublishProfile=release-linux-x64
    dotnet publish src/D365FO.Cli -c Release /p:PublishProfile=release-osx-arm64

  Override RID per invocation with /p:RuntimeIdentifier=<rid>.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <DebugType>embedded</DebugType>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">win-x64</RuntimeIdentifier>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\..\artifacts\$(RuntimeIdentifier)\</PublishDir>
  </PropertyGroup>
</Project>
